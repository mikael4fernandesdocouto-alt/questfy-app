generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum Rank {
  E
  D
  C
  B
  A
  S
}

enum Plan {
  FREE
  PRO
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Subject {
  MATEMATICA
  LINGUAGENS
  CIENCIAS_HUMANAS
  CIENCIAS_NATUREZA
  REDACAO
}

enum MissionType {
  DAILY
  WEEKLY
  SUBJECT
  STREAK
}

enum ExamType {
  ENEM
  ITA
  IME
  FUVEST
  UNICAMP
  CONCURSO
}

// ============ USER ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String    @map("password_hash")
  avatarUrl     String?   @map("avatar_url")
  rank          Rank      @default(E)
  level         Int       @default(1)
  xp            Int       @default(0)
  totalXp       Int       @default(0) @map("total_xp")
  xpToNextLevel Int       @default(100) @map("xp_to_next_level")
  streak        Int       @default(0)
  lastStudyDate DateTime? @map("last_study_date")
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  answers        Answer[]
  achievements   UserAchievement[]
  missions       UserMission[]
  examAttempts   ExamAttempt[]
  rankingEntries RankingEntry[]
  userTitles     UserTitle[]
  weeklyLogs     WeeklyLog[]

  @@map("users")
}

// ============ QUESTIONS ============

model Question {
  id          String     @id @default(cuid())
  statement   String
  imageUrl    String?    @map("image_url")
  difficulty  Difficulty
  subject     Subject
  examType    ExamType   @default(ENEM) @map("exam_type")
  examYear    Int?       @map("exam_year")
  explanation String?
  createdAt   DateTime   @default(now()) @map("created_at")

  alternatives Alternative[]
  answers      Answer[]

  @@index([subject, difficulty])
  @@index([examType, examYear])
  @@map("questions")
}

model Alternative {
  id         String  @id @default(cuid())
  text       String
  isCorrect  Boolean @map("is_correct")
  questionId String  @map("question_id")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("alternatives")
}

// ============ ANSWERS ============

model Answer {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  questionId    String   @map("question_id")
  selectedAltId String   @map("selected_alt_id")
  isCorrect     Boolean  @map("is_correct")
  xpEarned      Int      @map("xp_earned")
  answeredAt    DateTime @default(now()) @map("answered_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, answeredAt])
  @@map("answers")
}

// ============ MISSIONS ============

model Mission {
  id          String      @id @default(cuid())
  title       String
  description String
  type        MissionType
  xpReward    Int         @map("xp_reward")
  targetCount Int         @map("target_count")
  subject     Subject?
  difficulty  Difficulty?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")

  userMissions UserMission[]

  @@map("missions")
}

model UserMission {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  missionId   String    @map("mission_id")
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  assignedAt  DateTime  @default(now()) @map("assigned_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
  @@map("user_missions")
}

// ============ ACHIEVEMENTS ============

model Achievement {
  id          String @id @default(cuid())
  name        String @unique
  description String
  icon        String
  condition   String // JSON string
  xpBonus     Int    @default(0) @map("xp_bonus")

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ============ EXAMS (BOSS BATTLES) ============

model Exam {
  id        String   @id @default(cuid())
  title     String
  type      ExamType @default(ENEM)
  year      Int?
  subject   Subject?
  xpReward  Int      @default(300) @map("xp_reward")
  timeLimit Int?     @map("time_limit")
  createdAt DateTime @default(now()) @map("created_at")

  attempts ExamAttempt[]

  @@map("exams")
}

model ExamAttempt {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  examId     String    @map("exam_id")
  score      Int       @default(0)
  xpEarned   Int       @default(0) @map("xp_earned")
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("exam_attempts")
}

// ============ RANKING ============

model RankingEntry {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  season    String
  xpTotal   Int      @default(0) @map("xp_total")
  rank      Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, season])
  @@index([season, xpTotal])
  @@map("ranking_entries")
}

// ============ TITLES ============

model Title {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String
  icon         String
  requiredXp   Int      @map("required_xp")
  requiredRank Rank?
  createdAt    DateTime @default(now()) @map("created_at")

  userTitles UserTitle[]

  @@map("titles")
}

model UserTitle {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  titleId    String   @map("title_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title Title @relation(fields: [titleId], references: [id], onDelete: Cascade)

  @@unique([userId, titleId])
  @@map("user_titles")
}

// ============ WEEKLY LOG (for graphs) ============

model WeeklyLog {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  weekStart         DateTime @map("week_start")
  dayOfWeek         Int      @map("day_of_week")
  xpEarned          Int      @default(0) @map("xp_earned")
  questionsAnswered Int      @default(0) @map("questions_answered")
  correctAnswers    Int      @default(0) @map("correct_answers")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart, dayOfWeek])
  @@index([userId, weekStart])
  @@map("weekly_logs")
}
